					end
        elseif nR <= 39 then
					if world:IsGongUnLocked("Gong_5_Tu") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("Gong_5_Tu");   
