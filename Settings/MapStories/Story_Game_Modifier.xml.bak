<Stories><List>
	<Story Name="Game_Modifier"  Parent="BaseFillingStory">
		<DisplayName>ม็อดปรับแต่งเกม (หมายเหตุ : กดแค่ครั้งเดียว ถ้ากดหลายครั้งค่าจะติดลบ) </DisplayName>
		<Desc>กรุณาเลือกประเภทที่ต้องการแก้ไข</Desc>
		<Selections>
<li><Display>ย้อนกลับ</Display><OKResult></OKResult></li>
<li><Display>เพิ่มค่าสเตตัสทั้ง 5ของตัวละคร</Display><OKResult>me:AddModifier("QuanBu76");</OKResult></li>

<li><Display>ตัวละครตายยาก</Display><OKResult>
me:ModifierProperty("RecoveryPower",999);
me:ModifierProperty("MagicDamageRecoveryPowerAddV",9999);
me:ModifierProperty("LingAbsorbSpeed",1000);
me:ModifierProperty("NutritionToJingYuanK",1000);
me:ModifierProperty("NutritionWaterAutoRecover",1000);
me:TriggerStory("Game_Modifier");
</OKResult></li>
<li><Display>จัดการค่าใช้จ่ายทางโลกอัตโนมัติ</Display><OKResult>
me:ModifierProperty("FatigueConsumeConstant",-10);
me:ModifierProperty("WaterConsumeConstant",-10);
me:ModifierProperty("HappyConsumeConstant",-10);
me:ModifierProperty("NutritionConsumeConstant",-10);
me:ModifierProperty("PracticeFoodConsumeConstant",-10);
me:TriggerStory("Game_Modifier");</OKResult></li>

<li><Display>เพิ่มพรสวรรค์การบำเพ็ญเซียนเต็มขั้นในคลิกเดียว</Display><OKResult>
me:ModifierProperty("IntelligenceSkillEXPConstant",999);
me:ModifierProperty("PotentialOfBasepracticeAddValue",100000);
me:ModifierProperty("BasepracticeSpeedCoefficient",100000);
me:ModifierProperty("DeepPracticeSpeedSpecialCoefficient",100000);
me:ModifierProperty("MindStateBaseValue",100000);
me:ModifierProperty("SpeedOfMindStateCoefficient",100000);
me:ModifierProperty("SpeedOfMindStateCoefficientByMoods",-100000);
me:ModifierProperty("InspirationCoefficient",100000);
me:TriggerStory("Game_Modifier");</OKResult></li>

<li><Display>ปรับอัตราสำเร็จคุณภาพระดับเทพของการหลอมอาวุธและปรุงโอสถ </Display><OKResult>
