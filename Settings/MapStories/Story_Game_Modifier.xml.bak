          if world:IsGongUnLocked("God_Gong_1") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("God_Gong_1");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบวิชาอภินิหารบทหนึ่งอยู่ภายในอย่างไม่น่าเชื่อ”");me:DropEsotericFromCache(story.ItemCache2, 1);
					end
        elseif nR <= 48 then  
          if world:IsGongUnLocked("God_Gong_2") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("God_Gong_2");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบวัตถุดิบล้ำค่าจำนวนหนึ่งซ่อนอยู่ภายใน”");me:DropAwardItemFromCache(story.ItemCache3, 1);
					end
        elseif nR <= 51 then  
          if world:IsGongUnLocked("God_Gong_3") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("God_Gong_3");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบสมบัติล้ำค่าสมัยโบราณชิ้นหนึ่งอยู่ภายใน ซึ่งสามารถกดข่มฮวงจุ้ยได้”");me:DropRandomItem(tIL[world:RandomInt(1,#tIL+1)], 7, 11, true);
					end
				end
				]]>		
				</OKResult></li>




