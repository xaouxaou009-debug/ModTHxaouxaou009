me:TriggerStory("Game_Modifier");</OKResult></li>
<li><Display>ปรุงโอสถได้จำนวน 100 เท่า</Display><OKResult>me:ModifierProperty("DanMake_YieldAddP",100);
me:TriggerStory("Game_Modifier");</OKResult></li>
<li><Display>ปรับค่าสถานะการต่อสู้ด้านพลังโจมตีและป้องกัน</Display><OKResult>
me:ModifierProperty("NpcFight_BaseHitChance",1000);
me:ModifierProperty("NpcFight_BaseDodgeChance",1000);
me:ModifierProperty("NpcFight_ShieldConversionEquipAdd",1000);
me:ModifierProperty("NpcFight_FabaoNum",5);
me:ModifierProperty("NpcFight_FabaoLingRecoverK",1000);
me:ModifierProperty("NpcFight_FabaoPowerAddP",1000);
me:ModifierProperty("NpcFight_FabaoLingRecoverAddP",1000);
