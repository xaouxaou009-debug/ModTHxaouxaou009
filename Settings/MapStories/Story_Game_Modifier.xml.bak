<Story Name="LBQDZLZMNQ"  Parent="BaseFillingStory">
		<DisplayName>ม็อดเสริม</DisplayName>
		<Desc>“ฟังก์ชันนี้ จะมั่วๆหน่อยรวมๆกันไป แต่งตรงชื่อชื่อแน่นอน”</Desc>
		<Selections>
<li><Display>“ย้อนกลับ”</Display><OKResult>me:TriggerStory("Game_Modifier");</OKResult></li>
<li><Display>“หีบสมบัติคัมภีร์เซียน”</Display><OKResult>
				<![CDATA[	
				story:RemoveBindItem();
				local nR = me:RandomInt(1, 10);
				if nR <= 5 then
					me:AddMsg("หีบลับของ [NAME] เปล่งแสงสลัวออกมา ก่อนจะหลอมรวมเป็นคัมภีร์วิชาคุณภาพต่ำสุดแสนหยาบห่วย");world:UnlockRandomGong(1);
				elseif nR <= 7 then
					me:AddMsg("หีบลับของ [NAME] เปล่งแสงธรรมดาออกมา ก่อนจะหลอมรวมเป็นคัมภีร์วิชาที่แสนธรรมดาไร้ความโดดเด่น");world:UnlockRandomGong(2);
        elseif nR <= 9 then
					me:AddMsg("หีบลับของ [NAME] เปล่งแสงเจิดจ้าออกมา ก่อนจะหลอมรวมเป็นคัมภีร์วิชาที่แฝงไว้ด้วยความลึกล้ำ");world:UnlockRandomGong(3);
        else
          me:AddMsg("หีบลับของ [NAME] เปล่งแสงเจิดจ้าราวดวงอาทิตย์ ก่อนจะหลอมรวมเป็นคัมภีร์วิชาอันล้ำลึกเหนือหยั่ง");world:UnlockRandomGong(4);
				end
				]]>		
				</OKResult></li>
<li><Display>หีบหินโบราณ (แท้)</Display><OKResult>
				<![CDATA[	
				story:RemoveBindItem();
				local nR = me:RandomInt(1, 51); 
				local tIL = {"Wood","Rock","Metal","Weapon"};
				if nR <= 4 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบเข้ากับผังค่ายกลที่สูญหายไปนานเล่มหนึ่งอยู่ด้านใน”");me:DropEsotericFromCache(story.ItemCache4, 1);
				elseif nR <= 8 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบว่าด้านในซ่อนวัสดุล้ำค่าจำนวนหนึ่งเอาไว้”");me:DropAwardItemFromCache(story.ItemCache3, 1);
				elseif nR <= 12 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบว่าด้านในซ่อนสมบัติล้ำค่าโบราณชิ้นหนึ่งไว้ ซึ่งสามารถกดข่มฮวงจุ้ยได้”");me:DropRandomItem(tIL[world:RandomInt(1,#tIL+1)], 7, 11, true);
				elseif nR <= 15 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบหนังสือเล่มหนึ่งอยู่ด้านในอย่างคาดไม่ถึง”");me:DropEsotericFromCache(story.ItemCache, 1);
				elseif nR <= 18 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบวิชาอภินิหารบทหนึ่งอยู่ภายในอย่างไม่น่าเชื่อ”");me:DropEsotericFromCache(story.ItemCache2, 1);
				elseif nR <= 21 then
					me:AddMsg("“[NAME] เปิดหีบหินออก และพบคัมภีร์ลับเล่มหนึ่งอยู่ภายในอย่างไม่น่าเชื่อ”");me:DropRandomItem("Esoterica");
        elseif nR <= 24 then  
          if world:IsGongUnLocked("Gong_2_Mu") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีพุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้ความพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนาน”");me:UnLockGong("Gong_2_Mu");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบหนังสือเล่มหนึ่งอยู่ภายในอย่างคาดไม่ถึง”");me:DropEsotericFromCache(story.ItemCache, 1);
					end
        elseif nR <= 27 then  
          if world:IsGongUnLocked("Gong_3_Jin") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("Gong_3_Jin");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบวิชาอภินิหารบทหนึ่งอยู่ภายในอย่างไม่น่าเชื่อ”");me:DropEsotericFromCache(story.ItemCache2, 1);
					end
        elseif nR <= 30 then  
          if world:IsGongUnLocked("Gong_4_None") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("Gong_4_None");   
					else
						me:AddMsg("“[NAME] เปิดหีบหินออก และพบวัตถุดิบล้ำค่าจำนวนหนึ่งซ่อนอยู่ภายใน”");me:DropAwardItemFromCache(story.ItemCache3, 1);
					end
        elseif nR <= 33 then  
          if world:IsGongUnLocked("Gong_6_Huo") == false then
						me:AddMsg("“[NAME] เปิดหีบหินออก ทันใดนั้นแสงเจ็ดสีก็พุ่งทะยานขึ้นสู่ท้องฟ้า ภายในหีบหินธรรมดาไร้สิ่งพิเศษนี้ กลับซ่อนการสืบทอดวิชาบำเพ็ญโบราณที่สูญหายไปนานเล่มหนึ่งเอาไว้”");me:UnLockGong("Gong_6_Huo");   
					else
